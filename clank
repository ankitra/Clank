#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

DEFAULT_REPO_DIR="$HOME/claude-sandboxes/myproj"
REPO_DIR="${CLAUDE_SANDBOX_REPO:-$DEFAULT_REPO_DIR}"
IMAGE_NAME="${CLAUDE_DOCKER_IMAGE:-claude-code-local:latest}"
DOCKERFILE_PATH="$SCRIPT_DIR/Dockerfile"
BUILD_CONTEXT="$SCRIPT_DIR"

get_version() {
  if [[ -f "$SCRIPT_DIR/VERSION" ]]; then
    tr -d '\r\n' < "$SCRIPT_DIR/VERSION"
  else
    echo "unknown"
  fi
}

usage() {
  cat <<USAGE
Usage:
  $(basename "$0") [--repo PATH] [--rebuild] [--image NAME] [--] [claude args...]
  $(basename "$0") /path/to/repo [claude args...]

Examples:
  $(basename "$0") --repo ~/claude-sandboxes/myproj
  $(basename "$0") --repo ~/claude-sandboxes/myproj -- --model sonnet
  $(basename "$0") ~/claude-sandboxes/myproj --print "summarize this repo"

Notes:
  - If the first positional argument looks like a git repo, it is used as the repo path.
  - Everything else is forwarded to the 'claude' command inside the container.
  - ANTHROPIC_API_KEY is optional. If set in the host shell, it is passed through.
  - If ANTHROPIC_API_KEY is not set, Claude can use its own local config/auth inside the container.
USAGE
}

REBUILD=0
POSITIONAL=()
POSITIONAL_COUNT=0
CLAUDE_ARGS=()
CLAUDE_ARGS_COUNT=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo)
      [[ $# -ge 2 ]] || { echo "--repo requires a path" >&2; exit 1; }
      REPO_DIR="$2"
      shift 2
      ;;
    --image)
      [[ $# -ge 2 ]] || { echo "--image requires a value" >&2; exit 1; }
      IMAGE_NAME="$2"
      shift 2
      ;;
    --rebuild)
      REBUILD=1
      shift
      ;;
    --version|-V)
      get_version
      exit 0
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      while [[ $# -gt 0 ]]; do
        POSITIONAL+=("$1")
        POSITIONAL_COUNT=$((POSITIONAL_COUNT + 1))
        shift
      done
      break
      ;;
    *)
      POSITIONAL+=("$1")
      POSITIONAL_COUNT=$((POSITIONAL_COUNT + 1))
      shift
      ;;
  esac
done

if [[ $POSITIONAL_COUNT -gt 0 && -d "${POSITIONAL[0]}" && -d "${POSITIONAL[0]}/.git" ]]; then
  REPO_DIR="${POSITIONAL[0]}"
  if [[ $POSITIONAL_COUNT -gt 1 ]]; then
    CLAUDE_ARGS=("${POSITIONAL[@]:1}")
    CLAUDE_ARGS_COUNT=$((POSITIONAL_COUNT - 1))
  fi
elif [[ $POSITIONAL_COUNT -gt 0 ]]; then
  CLAUDE_ARGS=("${POSITIONAL[@]}")
  CLAUDE_ARGS_COUNT=$POSITIONAL_COUNT
fi

if [[ ! -d "$REPO_DIR" ]]; then
  echo "Repo directory does not exist: $REPO_DIR" >&2
  exit 1
fi

if [[ ! -d "$REPO_DIR/.git" ]]; then
  echo "Not a git repository: $REPO_DIR" >&2
  exit 1
fi

if [[ ! -f "$DOCKERFILE_PATH" ]]; then
  echo "Dockerfile not found next to script: $DOCKERFILE_PATH" >&2
  exit 1
fi

if ! command -v docker >/dev/null 2>&1; then
  echo "Docker CLI not found in PATH." >&2
  echo "Install Docker Desktop or a compatible Docker CLI/runtime setup such as Colima + docker CLI." >&2
  exit 1
fi

if ! docker info >/dev/null 2>&1; then
  echo "Docker is installed, but the daemon/runtime is not reachable." >&2
  echo "If you use Colima, try: colima start" >&2
  exit 1
fi

if [[ "$REBUILD" -eq 1 ]] || ! docker image inspect "$IMAGE_NAME" >/dev/null 2>&1; then
  echo "Building Docker image: $IMAGE_NAME"
  docker build -t "$IMAGE_NAME" -f "$DOCKERFILE_PATH" "$BUILD_CONTEXT"
fi

DOCKER_ENV_ARGS=(
  -e HOME=/tmp/claude-home
  -e GIT_TERMINAL_PROMPT=0
  -e GIT_CONFIG_GLOBAL=/dev/null
)

if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
  DOCKER_ENV_ARGS+=(-e "ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY")
fi

CONTAINER_NAME="claude-code-$(basename "$REPO_DIR" | tr '[:upper:]' '[:lower:]' | tr -cd 'a-z0-9-_')"

echo "Starting Claude Code in Docker..."
echo "Toolkit dir: $SCRIPT_DIR"
echo "Mounted repo: $REPO_DIR"
echo "Version: $(get_version)"
echo "Docker image: $IMAGE_NAME"
if [[ $CLAUDE_ARGS_COUNT -gt 0 ]]; then
  echo "Passing Claude args: ${CLAUDE_ARGS[*]}"
fi
if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
  echo "Auth source: host ANTHROPIC_API_KEY"
else
  echo "Auth source: container-local Claude config/auth"
fi
echo "Container will be removed when Claude exits."

if [[ $CLAUDE_ARGS_COUNT -gt 0 ]]; then
  docker run --rm -it \
    --name "$CONTAINER_NAME" \
    -v "$REPO_DIR:/workspace" \
    -w /workspace \
    "${DOCKER_ENV_ARGS[@]}" \
    "$IMAGE_NAME" \
    bash -lc '
      set -euo pipefail

      mkdir -p "$HOME"

      unset SSH_AUTH_SOCK
      unset GH_TOKEN
      unset GITHUB_TOKEN
      unset GIT_ASKPASS
      unset SSH_ASKPASS

      echo "Claude Code starting in /workspace"
      exec claude "$@"
    ' bash "${CLAUDE_ARGS[@]}"
else
  docker run --rm -it \
    --name "$CONTAINER_NAME" \
    -v "$REPO_DIR:/workspace" \
    -w /workspace \
    "${DOCKER_ENV_ARGS[@]}" \
    "$IMAGE_NAME" \
    bash -lc '
      set -euo pipefail

      mkdir -p "$HOME"

      unset SSH_AUTH_SOCK
      unset GH_TOKEN
      unset GITHUB_TOKEN
      unset GIT_ASKPASS
      unset SSH_ASKPASS

      echo "Claude Code starting in /workspace"
      exec claude
    '
fi
